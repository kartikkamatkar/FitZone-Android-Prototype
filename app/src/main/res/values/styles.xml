<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="ShapeAppearanceOverlay.FitZone.Card" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/card_radius_lg</item>
    </style>

    <style name="ShapeAppearanceOverlay.FitZone.Image" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">14dp</item>
    </style>

    <style name="ShapeAppearanceOverlay.FitZone.Avatar" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="Widget.FitZone.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/fitzone_card_background</item>
        <item name="cardCornerRadius">@dimen/card_radius_lg</item>
        <item name="cardElevation">@dimen/card_elevation_strong</item>
        <item name="cardMaxElevation">10dp</item>
        <item name="cardUseCompatPadding">true</item>
        <item name="rippleColor">@color/fitzone_accent_container</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlay.FitZone.Card</item>
        <item name="strokeColor">@color/fitzone_card_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.FitZone.MaterialCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/fitzone_card_background</item>
        <item name="cardCornerRadius">@dimen/card_radius_md</item>
        <item name="cardElevation">@dimen/card_elevation_soft</item>
        <item name="strokeColor">@color/fitzone_card_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="TextAppearance.FitZone.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/fitzone_primary</item>
        <item name="android:textSize">@dimen/text_title_lg</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.FitZone.Subtitle" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/fitzone_on_surface_variant</item>
        <item name="android:textSize">@dimen/text_subtitle</item>
    </style>

    <style name="TextAppearance.FitZone.BodyStrong" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/fitzone_on_surface</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.FitZone.PrimaryButton" parent="Widget.Material3.Button">
        <item name="android:minHeight">52dp</item>
        <item name="cornerRadius">18dp</item>
        <item name="backgroundTint">@color/fitzone_primary</item>
        <item name="android:textColor">@color/fitzone_on_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.FitZone.SecondaryButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">52dp</item>
        <item name="cornerRadius">18dp</item>
        <item name="strokeColor">@color/fitzone_primary</item>
        <item name="android:textColor">@color/fitzone_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.FitZone.OutlinedInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxStrokeColor">@color/fitzone_outline</item>
    </style>

    <style name="Widget.FitZone.FilterChip" parent="Widget.Material3.Chip.Filter">
        <item name="chipMinHeight">40dp</item>
        <item name="chipCornerRadius">20dp</item>
        <item name="chipBackgroundColor">@color/workout_chip_background</item>
        <item name="chipStrokeColor">@color/workout_chip_stroke</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="checkedIconVisible">false</item>
        <item name="android:textColor">@color/workout_chip_text</item>
        <item name="rippleColor">@color/fitzone_accent_container</item>
    </style>

    <style name="ShapeAppearanceOverlay.FitZone.BottomNavigationActiveIndicator" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">18dp</item>
    </style>

    <style name="Widget.FitZone.BottomNavigationView.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:width">64dp</item>
        <item name="android:height">34dp</item>
        <item name="marginHorizontal">10dp</item>
        <item name="color">@color/fitzone_bottom_nav_selected_bg</item>
        <item name="shapeAppearance">@style/ShapeAppearanceOverlay.FitZone.BottomNavigationActiveIndicator</item>
    </style>

    <style name="Widget.FitZone.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="itemActiveIndicatorStyle">@style/Widget.FitZone.BottomNavigationView.ActiveIndicator</item>
        <item name="itemRippleColor">@color/fitzone_accent_container</item>
    </style>

    <style name="Animation.FitZone.Window" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/fragment_fade_in</item>
        <item name="android:activityOpenExitAnimation">@anim/fragment_fade_out</item>
        <item name="android:activityCloseEnterAnimation">@anim/fragment_fade_in</item>
        <item name="android:activityCloseExitAnimation">@anim/fragment_fade_out</item>
    </style>
</resources>

