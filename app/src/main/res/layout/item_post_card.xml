<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginTop="150dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/fitzone_card_stroke"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Avatar - Modernized -->
        <ImageView
            android:id="@+id/postAvatarImage"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_chat_avatar"
            android:contentDescription="@null"
            android:padding="10dp"
            android:src="@drawable/profile_placeholder"
            android:elevation="2dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@null" />

        <!-- Username - Enhanced typography -->
        <TextView
            android:id="@+id/postUserNameText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/fitzone_on_surface"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintEnd_toStartOf="@id/postDateText"
            app:layout_constraintStart_toEndOf="@id/postAvatarImage"
            app:layout_constraintTop_toTopOf="@id/postAvatarImage"
            app:layout_constraintBottom_toTopOf="@id/postBodyText" />

        <!-- Date - Improved visibility -->
        <TextView
            android:id="@+id/postDateText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/fitzone_on_surface_variant"
            android:textSize="12sp"
            android:fontFamily="sans-serif"
            app:layout_constraintBaseline_toBaselineOf="@id/postUserNameText"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Post Body - Improved readability -->
        <TextView
            android:id="@+id/postBodyText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/fitzone_on_surface"
            android:textSize="15sp"
            android:fontFamily="sans-serif"
            android:lineSpacingExtra="3dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/postAvatarImage" />

        <!-- Post Image - Enhanced with rounded corners -->
        <ImageView
            android:id="@+id/postImageView"
            android:layout_width="0dp"
            android:layout_height="200dp"
            android:layout_marginTop="10dp"
            android:adjustViewBounds="true"
            android:background="@color/fitzone_surface_variant"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            android:src="@drawable/exercise_placeholder"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/postBodyText" />

        <LinearLayout
            android:id="@+id/postActionsRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:baselineAligned="false"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/postImageView">

            <ImageButton
                android:id="@+id/postLikeButton"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Like post"
                android:src="@android:drawable/btn_star_big_off"
                android:tint="@color/fitzone_primary" />

            <TextView
                android:id="@+id/postLikeCountText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="0"
                android:textColor="@color/fitzone_on_surface"
                android:textSize="13sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/postCommentButton"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="16dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Comment on post"
                android:src="@android:drawable/ic_menu_edit"
                android:tint="@color/fitzone_primary" />

            <TextView
                android:id="@+id/postCommentCountText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="0"
                android:textColor="@color/fitzone_on_surface"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>