<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fitzone_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">



    <LinearLayout
        android:id="@+id/homeScreenHeaderSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="40dp"
        android:paddingEnd="16dp"
        android:paddingBottom="6dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_fragment_title"
            android:textColor="@color/fitzone_on_surface"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/home_today_overview"
            android:textColor="@color/fitzone_on_surface_variant"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="80dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <!-- Header Card - Fixed camera cutout issue -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/homeHeaderCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                app:cardBackgroundColor="@color/fitzone_primary"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:cardPreventCornerOverlap="false"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@id/homeOverviewText"
                app:layout_constraintVertical_chainStyle="packed">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="20dp"
                    android:paddingTop="20dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="24dp">

                    <TextView
                        android:id="@+id/homeHeaderGreeting"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="16dp"
                        android:text="@string/home_header_greeting"
                        android:textColor="@color/fitzone_on_primary"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:letterSpacing="-0.01"
                        android:lineHeight="34sp"
                        app:layout_constraintEnd_toStartOf="@id/homeHeaderAvatar"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/homeHeaderSubtitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/home_header_subtitle"
                        android:textColor="#B3FFFFFF"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        app:layout_constraintEnd_toEndOf="@id/homeHeaderGreeting"
                        app:layout_constraintStart_toStartOf="@id/homeHeaderGreeting"
                        app:layout_constraintTop_toBottomOf="@id/homeHeaderGreeting" />

                    <ImageView
                        android:id="@+id/homeHeaderAvatar"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_chat_avatar"
                        android:contentDescription="@string/home_header_avatar_cd"
                        android:padding="10dp"
                        android:src="@drawable/profile_placeholder"
                        android:importantForAccessibility="yes"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@null" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Today's Overview Label -->
            <TextView
                android:id="@+id/homeOverviewText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/home_today_overview"
                android:textColor="@color/fitzone_on_surface_variant"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.04"
                android:textAllCaps="true"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/homeHeaderCard" />

            <!-- Calories Card - Compact and balanced -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/caloriesCard"
                style="@style/Widget.FitZone.MaterialCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/homeOverviewText">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:weightSum="2">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_compass"
                            app:tint="@color/fitzone_primary" />

                        <TextView
                            android:id="@+id/homeCaloriesBurnedValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/home_calories_burned_value"
                            android:textColor="@color/fitzone_on_surface"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-black" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/home_calories_burned_label"
                            android:textColor="@color/fitzone_on_surface_variant"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:layout_marginHorizontal="12dp"
                        android:background="@color/fitzone_outline" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_recent_history"
                            app:tint="@color/fitzone_primary" />

                        <TextView
                            android:id="@+id/homeCaloriesLeftValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/home_calories_left_value"
                            android:textColor="@color/fitzone_on_surface"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-black" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/home_calories_left_label"
                            android:textColor="@color/fitzone_on_surface_variant"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Water Intake Tracker Card - Modern progress display -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/waterIntakeCard"
                style="@style/Widget.FitZone.MaterialCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/caloriesCard">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/waterIcon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/home_water_intake_cd"
                        android:src="@android:drawable/ic_menu_view"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/fitzone_primary" />

                    <TextView
                        android:id="@+id/waterTitleText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Water Intake"
                        android:textColor="@color/fitzone_on_surface"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/waterIcon"
                        app:layout_constraintTop_toTopOf="@id/waterIcon"
                        app:layout_constraintBottom_toBottomOf="@id/waterIcon" />

                    <TextView
                        android:id="@+id/waterIntakeLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="0 / 8 glasses"
                        android:textColor="@color/fitzone_on_surface"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/waterTitleText" />

                    <!-- Progress Bar - Styled for MD3 -->
                    <ProgressBar
                        android:id="@+id/waterProgressBar"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="0dp"
                        android:layout_height="8dp"
                        android:layout_marginTop="8dp"
                        android:indeterminate="false"
                        android:max="100"
                        android:progress="0"
                        android:progressTint="@color/fitzone_primary"
                        android:progressBackgroundTint="@color/fitzone_outline"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/waterIntakeLabel" />

                    <!-- Add Water Button - Contained button style -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/addWaterButton"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_marginTop="16dp"
                        android:text="+ Add Water"
                        android:textAllCaps="false"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        app:cornerRadius="20dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/waterProgressBar"
                        app:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Workout Streak Card - Improved accent usage -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/streakCard"
                style="@style/Widget.FitZone.MaterialCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/waterIntakeCard">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/streakIcon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/home_streak_icon_cd"
                        android:src="@android:drawable/ic_menu_compass"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/fitzone_accent" />

                    <TextView
                        android:id="@+id/streakTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Workout Streak"
                        android:textColor="@color/fitzone_on_surface"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/streakIcon"
                        app:layout_constraintTop_toTopOf="@id/streakIcon"
                        app:layout_constraintBottom_toBottomOf="@id/streakIcon" />

                    <TextView
                        android:id="@+id/streakCounterText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="0 days"
                        android:textColor="@color/fitzone_accent"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-black"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/streakTitle" />

                    <TextView
                        android:id="@+id/streakMessageText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="No streak yet. Start working out!"
                        android:textColor="@color/fitzone_on_surface_variant"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/streakCounterText"
                        app:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Workout Card - Improved structure and grouping -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/workoutCard"
                style="@style/Widget.FitZone.MaterialCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/streakCard">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/workoutIcon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_media_play"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/fitzone_primary" />

                    <TextView
                        android:id="@+id/workoutTitleText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/home_workout_title"
                        android:textColor="@color/fitzone_on_surface"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/workoutIcon"
                        app:layout_constraintTop_toTopOf="@id/workoutIcon"
                        app:layout_constraintBottom_toBottomOf="@id/workoutIcon" />

                    <TextView
                        android:id="@+id/workoutSubtitleText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/home_workout_subtitle"
                        android:textColor="@color/fitzone_on_surface_variant"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toEndOf="@id/workoutTitleText"
                        app:layout_constraintStart_toStartOf="@id/workoutTitleText"
                        app:layout_constraintTop_toBottomOf="@id/workoutTitleText" />

                    <!-- Divider for visual separation -->
                    <View
                        android:id="@+id/workoutDivider"
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:background="@color/fitzone_outline"
                        android:alpha="0.3"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/workoutSubtitleText" />

                    <!-- Exercises Section - Grouped -->
                    <TextView
                        android:id="@+id/workoutExercisesLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Exercises:"
                        android:textColor="@color/fitzone_on_surface"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.03"
                        android:textAllCaps="true"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/workoutDivider" />

                    <TextView
                        android:id="@+id/workoutExercisesText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Loading exercises..."
                        android:textColor="@color/fitzone_on_surface"
                        android:textSize="14sp"
                        android:lineSpacingExtra="4dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/workoutExercisesLabel" />

                    <!-- Calories Section - Grouped -->
                    <TextView
                        android:id="@+id/workoutCaloriesLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Calories Burned:"
                        android:textColor="@color/fitzone_on_surface"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.03"
                        android:textAllCaps="true"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/workoutExercisesText" />

                    <TextView
                        android:id="@+id/workoutCaloriesText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="~450 calories"
                        android:textColor="@color/fitzone_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/workoutCaloriesLabel" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/startWorkoutButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginTop="16dp"
                        android:text="@string/home_start_workout"
                        android:textAllCaps="false"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        app:cornerRadius="24dp"
                        app:icon="@android:drawable/ic_media_play"
                        app:iconGravity="textStart"
                        app:iconTint="@color/fitzone_on_accent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/workoutCaloriesText"
                        app:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Mini Cards - Side by side with proper proportions -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/caloriesLeftCard"
                style="@style/Widget.FitZone.MaterialCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:layout_constraintEnd_toStartOf="@id/bmiCard"
                app:layout_constraintHorizontal_chainStyle="spread"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/workoutCard">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/ic_menu_recent_history"
                        app:tint="@color/fitzone_primary" />

                    <TextView
                        android:id="@+id/homeCaloriesLeftMiniValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/home_calories_left_value"
                        android:textColor="@color/fitzone_on_surface"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-black" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_calories_left_label"
                        android:textColor="@color/fitzone_on_surface_variant"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/bmiCard"
                style="@style/Widget.FitZone.MaterialCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/caloriesLeftCard"
                app:layout_constraintTop_toTopOf="@id/caloriesLeftCard">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/ic_menu_info_details"
                        app:tint="@color/fitzone_primary" />

                    <TextView
                        android:id="@+id/homeBmiValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/home_bmi_value"
                        android:textColor="@color/fitzone_on_surface"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-black" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_bmi_label"
                        android:textColor="@color/fitzone_on_surface_variant"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Quick Actions Title -->
            <TextView
                android:id="@+id/quickActionsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/home_quick_actions"
                android:textColor="@color/fitzone_on_surface"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/caloriesLeftCard" />

            <!-- Quick Action Cards - Interactive with ripple -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/actionWorkoutsCard"
                style="@style/Widget.FitZone.MaterialCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:foreground="?selectableItemBackground"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:layout_constraintEnd_toStartOf="@id/actionDietCard"
                app:layout_constraintHorizontal_chainStyle="spread"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/quickActionsTitle">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@android:drawable/ic_menu_manage"
                        app:tint="@color/fitzone_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/home_action_workouts"
                        android:textColor="@color/fitzone_on_surface"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/actionDietCard"
                style="@style/Widget.FitZone.MaterialCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="12dp"
                android:foreground="?selectableItemBackground"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/actionWorkoutsCard"
                app:layout_constraintTop_toTopOf="@id/actionWorkoutsCard">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@android:drawable/ic_menu_agenda"
                        app:tint="@color/fitzone_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/home_action_diet"
                        android:textColor="@color/fitzone_on_surface"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/actionTrackBmiCard"
                style="@style/Widget.FitZone.MaterialCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:foreground="?selectableItemBackground"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:layout_constraintEnd_toStartOf="@id/actionChatCard"
                app:layout_constraintHorizontal_chainStyle="spread"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/actionWorkoutsCard">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@android:drawable/ic_menu_edit"
                        app:tint="@color/fitzone_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/home_action_bmi"
                        android:textColor="@color/fitzone_on_surface"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/actionChatCard"
                style="@style/Widget.FitZone.MaterialCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:foreground="?selectableItemBackground"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/actionTrackBmiCard"
                app:layout_constraintTop_toTopOf="@id/actionTrackBmiCard">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp"
                    tools:ignore="UseCompoundDrawables">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@android:drawable/ic_menu_send"
                        app:tint="@color/fitzone_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/home_action_chat"
                        android:textColor="@color/fitzone_on_surface"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Feed Title - Integrated with community feel -->
            <TextView
                android:id="@+id/homeFeedTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/home_feed_title"
                android:textColor="@color/fitzone_on_surface"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/actionTrackBmiCard" />

            <!-- Inline Create Post Card - Integrated seamlessly -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/inlineCreatePostCard"
                style="@style/Widget.FitZone.MaterialCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="1dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/homeFeedTitle">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="64dp"
                    android:padding="12dp">

                    <ImageView
                        android:id="@+id/inlineCreatePostAvatar"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_chat_avatar"
                        android:contentDescription="@string/home_header_avatar_cd"
                        android:padding="8dp"
                        android:src="@drawable/profile_placeholder"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@null" />

                    <TextView
                        android:id="@+id/inlineCreatePostHint"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_inline_post_field"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:text="@string/home_create_post_hint"
                        android:textColor="@color/fitzone_on_surface_variant"
                        android:textSize="14sp"
                        app:layout_constraintBottom_toBottomOf="@id/inlineCreatePostAvatar"
                        app:layout_constraintEnd_toStartOf="@id/inlineCreatePostIcon"
                        app:layout_constraintStart_toEndOf="@id/inlineCreatePostAvatar"
                        app:layout_constraintTop_toTopOf="@id/inlineCreatePostAvatar" />

                    <ImageView
                        android:id="@+id/inlineCreatePostIcon"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="12dp"
                        android:contentDescription="@string/post_fab_content_description"
                        android:src="@android:drawable/ic_menu_camera"
                        app:layout_constraintBottom_toBottomOf="@id/inlineCreatePostHint"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/inlineCreatePostHint"
                        app:layout_constraintTop_toTopOf="@id/inlineCreatePostHint"
                        app:tint="@color/fitzone_primary" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Empty Feed Text - Minimal and clean -->
            <TextView
                android:id="@+id/homeEmptyFeedText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:text="@string/home_feed_empty"
                android:textColor="@color/fitzone_on_surface_variant"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/inlineCreatePostCard" />

            <!-- RecyclerView - Clean integration -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/homeFeedRecyclerView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/homeEmptyFeedText"
                tools:listitem="@layout/item_post_card" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/createPostFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="5dp"
        android:contentDescription="@string/post_fab_content_description"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/fitzone_primary"
        app:tint="@color/fitzone_on_primary" />

</FrameLayout>
