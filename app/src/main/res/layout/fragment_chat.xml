<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fitzone_background"
    android:orientation="vertical">

    <!-- Secondary screen header (matches Home's two-line header) -->
    <LinearLayout
        android:id="@+id/chatScreenHeaderSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="10dp"
        android:paddingEnd="16dp"
        android:paddingBottom="6dp">

        <TextView
            android:layout_marginTop="40dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/chat_fragment_title"
            android:textColor="@color/fitzone_on_surface"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/chat_status"
            android:textColor="@color/fitzone_on_surface_variant"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Content -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/fitzone_background"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp">

        <!-- Chat Header Card - Modernized -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/chatHeaderCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@android:color/white"
            app:strokeColor="@color/fitzone_card_stroke"
            app:strokeWidth="1dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp">

                <ImageView
                    android:id="@+id/chatHeaderAvatar"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_chat_avatar"
                    android:contentDescription="@string/chat_avatar_content_description"
                    android:padding="12dp"
                    android:src="@drawable/ic_chatbot_avatar"
                    android:elevation="2dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@null" />

                <TextView
                    android:id="@+id/chatHeaderTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="@string/chat_title"
                    android:textColor="@color/fitzone_on_surface"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/chatHeaderAvatar"
                    app:layout_constraintTop_toTopOf="@id/chatHeaderAvatar" />

                <TextView
                    android:id="@+id/chatHeaderStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/chat_status"
                    android:textColor="@color/fitzone_on_surface_variant"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif"
                    app:layout_constraintEnd_toEndOf="@id/chatHeaderTitle"
                    app:layout_constraintStart_toStartOf="@id/chatHeaderTitle"
                    app:layout_constraintTop_toBottomOf="@id/chatHeaderTitle" />

                <!-- Status Indicator - Modernized -->
                <LinearLayout
                    android:id="@+id/chatStatusContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp"
                    app:layout_constraintStart_toStartOf="@id/chatHeaderStatus"
                    app:layout_constraintTop_toBottomOf="@id/chatHeaderStatus">

                    <View
                        android:id="@+id/chatOnlineDot"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_chat_online_dot" />

                    <TextView
                        android:id="@+id/chatOnlineText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="@string/chat_online"
                        android:textColor="@color/fitzone_online"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Messages RecyclerView - Improved spacing -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/chatRecyclerView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layoutAnimation="@anim/layout_fade_in"
            android:clipToPadding="false"
            android:paddingStart="4dp"
            android:paddingTop="12dp"
            android:paddingEnd="4dp"
            android:paddingBottom="12dp"
            android:overScrollMode="never"
            app:layout_constraintBottom_toTopOf="@id/chatComposerCard"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/chatHeaderCard" />

        <!-- Chat Composer Card - Modern floating style -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/chatComposerCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@android:color/white"
            app:strokeWidth="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="6dp"
                android:paddingStart="12dp"
                android:paddingEnd="6dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/chatInputLayout"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:hint="@string/chat_input_hint"
                    app:boxBackgroundColor="@color/fitzone_chat_input_background"
                    app:boxCornerRadiusBottomEnd="24dp"
                    app:boxCornerRadiusBottomStart="24dp"
                    app:boxCornerRadiusTopEnd="24dp"
                    app:boxCornerRadiusTopStart="24dp"
                    app:boxStrokeColor="@color/fitzone_outline"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:hintTextColor="@color/fitzone_primary"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/sendButton"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/chatInputEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapSentences|textMultiLine"
                        android:maxLines="3"
                        android:minHeight="44dp"
                        android:textSize="15sp"
                        android:lineSpacingExtra="2dp"
                        android:paddingStart="16dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="10dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/sendButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="4dp"
                    android:minWidth="0dp"
                    android:text=""
                    android:contentDescription="@string/chat_send_content_description"
                    app:cornerRadius="24dp"
                    app:icon="@android:drawable/ic_menu_send"
                    app:iconSize="20dp"
                    app:iconTint="@color/fitzone_on_primary"
                    app:backgroundTint="@color/fitzone_primary"
                    app:rippleColor="@color/fitzone_primary"
                    app:elevation="2dp"
                    app:layout_constraintBottom_toBottomOf="@id/chatInputLayout"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/chatInputLayout" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</LinearLayout>