<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/fitzone_card_stroke"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="120dp"
        android:padding="16dp">

        <!-- Workout Image - Modernized -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/imageContainer"
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/fitzone_surface_variant"
            app:strokeWidth="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/workoutImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:padding="20dp"
                android:src="@drawable/exercise_placeholder"
                android:scaleType="centerInside"
                app:tint="@color/fitzone_primary" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Workout Name - Enhanced typography -->
        <TextView
            android:id="@+id/workoutName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:maxLines="2"
            android:textColor="@color/fitzone_on_surface"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.01"
            app:layout_constraintEnd_toStartOf="@id/startWorkoutButton"
            app:layout_constraintStart_toEndOf="@id/imageContainer"
            app:layout_constraintTop_toTopOf="@id/imageContainer" />

        <!-- Sets - Improved readability -->
        <TextView
            android:id="@+id/workoutSets"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:textColor="@color/fitzone_on_surface_variant"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintStart_toEndOf="@id/imageContainer"
            app:layout_constraintTop_toBottomOf="@id/workoutName" />

        <!-- Reps - Improved readability -->
        <TextView
            android:id="@+id/workoutReps"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="2dp"
            android:textColor="@color/fitzone_on_surface_variant"
            android:textSize="13sp"
            android:fontFamily="sans-serif"
            app:layout_constraintStart_toEndOf="@id/imageContainer"
            app:layout_constraintTop_toBottomOf="@id/workoutSets" />

        <!-- Status - Enhanced visibility -->
        <TextView
            android:id="@+id/workoutStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="2dp"
            android:text="@string/workout_status_not_started"
            android:textColor="@color/fitzone_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintStart_toEndOf="@id/imageContainer"
            app:layout_constraintTop_toBottomOf="@id/workoutReps" />

        <!-- Start Button - Modern pill style -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/startWorkoutButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:minWidth="0dp"
            android:text=""
            android:padding="2dp"
            android:contentDescription="@string/workout_start"
            app:icon="@android:drawable/ic_media_play"
            app:iconSize="24dp"
            app:iconTint="@color/fitzone_on_primary"
            app:cornerRadius="24dp"
            app:backgroundTint="@color/fitzone_primary"
            app:rippleColor="@color/fitzone_primary"
            app:elevation="2dp"
            app:layout_constraintBottom_toBottomOf="@id/imageContainer"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/imageContainer" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>