<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fitzone_background"
    android:orientation="vertical">


    <!-- Secondary screen header (matches Home's two-line header) -->
    <LinearLayout
        android:id="@+id/dietScreenHeaderSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="40dp"
        android:paddingEnd="16dp"
        android:paddingBottom="6dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/diet_fragment_title"
            android:textColor="@color/fitzone_on_surface"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/diet_subtitle"
            android:textColor="@color/fitzone_on_surface_variant"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/fitzone_background"
        android:clipToPadding="false">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <!-- Diet Header Card - Modernized with gradient background -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/dietHeaderCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/fitzone_primary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="20dp"
                android:paddingTop="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="20dp">

                <TextView
                    android:id="@+id/dietHeaderTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:text="@string/diet_header_title"
                    android:textColor="@color/fitzone_on_primary"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="-0.01"
                    app:layout_constraintEnd_toStartOf="@id/dietHeaderIcon"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/dietHeaderSubtitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/diet_header_subtitle"
                    android:textColor="#E8FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    app:layout_constraintEnd_toEndOf="@id/dietHeaderTitle"
                    app:layout_constraintStart_toStartOf="@id/dietHeaderTitle"
                    app:layout_constraintTop_toBottomOf="@id/dietHeaderTitle" />

                <ImageView
                    android:id="@+id/dietHeaderIcon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:contentDescription="@string/diet_header_icon_cd"
                    android:src="@drawable/ic_nav_diet"
                    app:layout_constraintBottom_toBottomOf="@id/dietHeaderTitle"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/dietHeaderTitle"
                    app:tint="@color/fitzone_on_primary" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Day Navigation Card - Modernized -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/dayNavCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@android:color/white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/dietHeaderCard">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="64dp">

                <ImageButton
                    android:id="@+id/dietPrevDay"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Previous day"
                    android:src="@android:drawable/ic_media_previous"
                    android:padding="12dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/fitzone_primary" />

                <TextView
                    android:id="@+id/dietDayLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Monday's Plan"
                    android:textColor="@color/fitzone_on_surface"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/dietNextDay"
                    app:layout_constraintStart_toEndOf="@id/dietPrevDay"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageButton
                    android:id="@+id/dietNextDay"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Next day"
                    android:src="@android:drawable/ic_media_next"
                    android:padding="12dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/fitzone_primary" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Meals Title - Improved typography -->
        <TextView
            android:id="@+id/mealsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Today's Meals"
            android:textColor="@color/fitzone_on_surface"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/dayNavCard" />

        <!-- Meals RecyclerView - Better container spacing -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/mealsRecyclerView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"
            android:paddingHorizontal="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/mealsTitle" />

        <!-- Total Daily Summary - Modernized with better nutrient layout -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/dailySummaryCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@android:color/white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/mealsRecyclerView">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <TextView
                    android:id="@+id/summaryTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Daily Total"
                    android:textColor="@color/fitzone_on_surface"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Divider -->
                <View
                    android:id="@+id/summaryDivider"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:background="@color/fitzone_outline"
                    android:alpha="0.3"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/summaryTitle" />

                <!-- Nutrient Grid - Using LinearLayout for better compatibility -->
                <LinearLayout
                    android:id="@+id/nutrientGrid"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:weightSum="4"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/summaryDivider">

                    <!-- Calories Column -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Calories"
                            android:textColor="@color/fitzone_on_surface_variant"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/totalCaloriesValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1,570"
                            android:textColor="@color/fitzone_primary"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-black" />
                    </LinearLayout>

                    <!-- Protein Column -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Protein"
                            android:textColor="@color/fitzone_on_surface_variant"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/totalProteinValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="96 g"
                            android:textColor="@color/fitzone_primary"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-black" />
                    </LinearLayout>

                    <!-- Carbs Column -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Carbs"
                            android:textColor="@color/fitzone_on_surface_variant"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/totalCarbsValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="146 g"
                            android:textColor="@color/fitzone_primary"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-black" />
                    </LinearLayout>

                    <!-- Fat Column -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fat"
                            android:textColor="@color/fitzone_on_surface_variant"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/totalFatValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="50 g"
                            android:textColor="@color/fitzone_primary"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-black" />
                    </LinearLayout>

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
