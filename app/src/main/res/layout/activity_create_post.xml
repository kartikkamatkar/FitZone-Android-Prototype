<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fitzone_background"
    android:clipToPadding="false">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/postCreateTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/post_create_title"
            android:layout_marginTop="100dp"
            android:textColor="@color/fitzone_on_surface"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.01"
            android:lineHeight="34sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/postCreateSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/post_create_subtitle"
            android:textColor="@color/fitzone_on_surface_variant"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintStart_toStartOf="@id/postCreateTitle"
            app:layout_constraintTop_toBottomOf="@id/postCreateTitle" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/postInputCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@android:color/white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/postCreateSubtitle">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/postTextInputLayout"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/post_text_hint"
                    app:boxCornerRadiusTopStart="16dp"
                    app:boxCornerRadiusTopEnd="16dp"
                    app:boxCornerRadiusBottomStart="16dp"
                    app:boxCornerRadiusBottomEnd="16dp"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:boxStrokeColor="@color/fitzone_primary"
                    app:hintTextColor="@color/fitzone_primary"
                    app:endIconMode="clear_text"
                    app:endIconTint="@color/fitzone_primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/postTextEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top|start"
                        android:inputType="textCapSentences|textMultiLine"
                        android:minLines="4"
                        android:maxLines="6"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp"
                        android:paddingStart="16dp"
                        android:paddingTop="12dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="12dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/pickImageButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="16dp"
                    android:text="@string/post_pick_image"
                    android:textAllCaps="false"
                    android:textSize="14sp"
                    android:textColor="@color/fitzone_primary"
                    android:fontFamily="sans-serif-medium"
                    app:cornerRadius="24dp"
                    app:icon="@android:drawable/ic_menu_gallery"
                    app:iconGravity="textStart"
                    app:iconTint="@color/fitzone_primary"
                    app:backgroundTint="@android:color/transparent"
                    app:rippleColor="@color/fitzone_primary"
                    app:strokeColor="@color/fitzone_primary"
                    app:strokeWidth="1dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Image Preview Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/imagePreviewCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@android:color/white"
            app:strokeWidth="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/postInputCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Image Preview Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:gravity="center_vertical"
                    android:background="@color/fitzone_surface">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Image Preview"
                        android:textColor="@color/fitzone_on_surface"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />

                    <ImageView
                        android:id="@+id/removeImageButton"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        android:contentDescription="Remove image"
                        android:padding="4dp"
                        android:background="?selectableItemBackgroundBorderless"
                        app:tint="@color/fitzone_on_surface_variant" />
                </LinearLayout>

                <!-- Image Preview -->
                <ImageView
                    android:id="@+id/postImagePreview"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:adjustViewBounds="true"
                    android:scaleType="centerCrop"
                    android:contentDescription="@string/post_image_preview" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Publish Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/publishPostButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="@string/post_publish_button"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            app:cornerRadius="28dp"
            app:icon="@android:drawable/ic_menu_send"
            app:iconGravity="textStart"
            app:iconTint="@color/fitzone_on_primary"
            app:backgroundTint="@color/fitzone_primary"
            app:rippleColor="@color/fitzone_primary"
            app:elevation="2dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/imagePreviewCard" />

        <!-- Character Counter (Optional enhancement) -->
        <TextView
            android:id="@+id/charCounterText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="4dp"
            android:text="0/500"
            android:textColor="@color/fitzone_on_surface_variant"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintEnd_toEndOf="@id/postInputCard"
            app:layout_constraintTop_toBottomOf="@id/postInputCard" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>