<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fitzone_background"
    android:clipToPadding="false"
    tools:context=".EditProfileActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_marginTop="40dp"
            android:id="@+id/editProfileTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/profile_edit_title"
            android:textColor="@color/fitzone_on_surface"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.01"
            android:lineHeight="34sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/editProfileSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/profile_edit_subtitle"
            android:textColor="@color/fitzone_on_surface_variant"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintStart_toStartOf="@id/editProfileTitle"
            app:layout_constraintTop_toBottomOf="@id/editProfileTitle" />

        <!-- Profile Form Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/profileFormCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@android:color/white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/editProfileSubtitle">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Profile Avatar Section (Optional enhancement) -->
                <LinearLayout
                    android:id="@+id/profileAvatarRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:id="@+id/profileAvatarPreview"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@drawable/profile_placeholder"
                        android:background="@drawable/bg_chat_avatar"
                        android:padding="12dp"
                        android:contentDescription="Profile avatar"
                        app:tint="@null" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Profile Photo"
                            android:textColor="@color/fitzone_on_surface"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tap to change your photo"
                            android:textColor="@color/fitzone_on_surface_variant"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/profileAvatarCameraButton"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_camera"
                        android:contentDescription="Change photo"
                        android:padding="4dp"
                        android:background="?selectableItemBackgroundBorderless"
                        app:tint="@color/fitzone_primary" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/fitzone_outline"
                    android:alpha="0.3"
                    android:layout_marginBottom="16dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/editNameInputLayout"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/name_hint"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:boxStrokeColor="@color/fitzone_primary"
                    app:hintTextColor="@color/fitzone_primary"
                    app:endIconMode="clear_text"
                    app:endIconTint="@color/fitzone_primary"
                    app:startIconDrawable="@android:drawable/ic_menu_edit"
                    app:startIconTint="@color/fitzone_primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editNameEditText"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:inputType="textPersonName"
                        android:maxLines="1"
                        android:textSize="16sp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/editAgeInputLayout"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="@string/age_hint"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:boxStrokeColor="@color/fitzone_primary"
                    app:hintTextColor="@color/fitzone_primary"
                    app:endIconMode="clear_text"
                    app:endIconTint="@color/fitzone_primary"
                    app:startIconDrawable="@android:drawable/ic_menu_today"
                    app:startIconTint="@color/fitzone_primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editAgeEditText"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:inputType="number"
                        android:maxLines="1"
                        android:textSize="16sp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/editHeightInputLayout"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="@string/height_hint"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:boxStrokeColor="@color/fitzone_primary"
                    app:hintTextColor="@color/fitzone_primary"
                    app:endIconMode="clear_text"
                    app:endIconTint="@color/fitzone_primary"
                    app:startIconDrawable="@android:drawable/ic_menu_sort_by_size"
                    app:startIconTint="@color/fitzone_primary"
                    app:suffixText="cm">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editHeightEditText"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:inputType="numberDecimal"
                        android:maxLines="1"
                        android:textSize="16sp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/editWeightInputLayout"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="@string/weight_hint"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:boxStrokeColor="@color/fitzone_primary"
                    app:hintTextColor="@color/fitzone_primary"
                    app:endIconMode="clear_text"
                    app:endIconTint="@color/fitzone_primary"
                    app:startIconDrawable="@android:drawable/ic_menu_manage"
                    app:startIconTint="@color/fitzone_primary"
                    app:suffixText="kg">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editWeightEditText"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:inputType="numberDecimal"
                        android:maxLines="1"
                        android:textSize="16sp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Save Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/saveProfileButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="@string/profile_save_button"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            app:cornerRadius="28dp"
            app:backgroundTint="@color/fitzone_primary"
            app:rippleColor="@color/fitzone_primary"
            app:elevation="2dp"
            app:icon="@android:drawable/ic_menu_save"
            app:iconGravity="textStart"
            app:iconTint="@color/fitzone_on_primary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/profileFormCard" />

        <!-- Optional: Last updated text -->
        <TextView
            android:id="@+id/lastUpdatedText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Last updated: Today"
            android:textColor="@color/fitzone_on_surface_variant"
            android:textSize="11sp"
            android:fontFamily="sans-serif"
            android:alpha="0.7"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/saveProfileButton" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>