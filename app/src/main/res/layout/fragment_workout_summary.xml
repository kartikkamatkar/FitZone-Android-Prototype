<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fitzone_background"
    android:orientation="vertical">



    <!-- Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <!-- Summary Card - Modernized -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/summaryCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp">

                    <!-- Success Icon - Enhanced emphasis -->
                    <ImageView
                        android:id="@+id/summaryIcon"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:contentDescription="@string/home_workout_cd"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_workout_complete"
                        android:elevation="4dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/fitzone_accent" />

                    <!-- Workout Name - Improved typography -->
                    <TextView
                        android:id="@+id/workoutNameSummary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="30dp"
                        android:text="@string/summary_workout_default_name"
                        android:textAlignment="center"
                        android:textColor="@color/fitzone_on_surface"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="-0.01"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/summaryIcon" />

                    <!-- Completion Message - Enhanced -->
                    <TextView
                        android:id="@+id/completionText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/summary_workout_completed"
                        android:textAlignment="center"
                        android:textColor="@color/fitzone_accent"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/workoutNameSummary" />

                    <!-- Modern Progress Bar -->
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/summaryProgressBar"
                        android:layout_width="0dp"
                        android:layout_height="8dp"
                        android:layout_marginTop="24dp"
                        android:max="100"
                        android:progress="100"
                        app:indicatorColor="@color/fitzone_accent"
                        app:trackColor="@color/fitzone_outline"
                        app:trackCornerRadius="4dp"
                        app:trackThickness="8dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/completionText" />

                    <!-- Stats - Using LinearLayout with weights for better compatibility -->
                    <LinearLayout
                        android:id="@+id/statsLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:orientation="horizontal"
                        android:weightSum="3"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/summaryProgressBar">

                        <!-- Duration Column -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Duration"
                                android:textColor="@color/fitzone_on_surface_variant"
                                android:textSize="12sp"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/durationSummary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="30:00"
                                android:textColor="@color/fitzone_accent"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-black" />
                        </LinearLayout>

                        <!-- Calories Column -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Calories"
                                android:textColor="@color/fitzone_on_surface_variant"
                                android:textSize="12sp"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/caloriesSummary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="~350 cal"
                                android:textColor="@color/fitzone_accent"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-black" />
                        </LinearLayout>

                        <!-- Distance Column -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Distance"
                                android:textColor="@color/fitzone_on_surface_variant"
                                android:textSize="12sp"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/distanceSummary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2.5 km"
                                android:textColor="@color/fitzone_accent"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-black" />
                        </LinearLayout>

                    </LinearLayout>

                    <!-- Divider for visual separation -->
                    <View
                        android:id="@+id/summaryDivider"
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_marginTop="20dp"
                        android:background="@color/fitzone_outline"
                        android:alpha="0.3"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/statsLayout" />

                    <!-- Finish Button - Enhanced styling -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/finishButton"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_marginTop="20dp"
                        android:text="Back to Home"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        app:cornerRadius="28dp"
                        app:backgroundTint="@color/fitzone_primary"
                        app:rippleColor="@color/fitzone_primary"
                        app:elevation="2dp"
                        app:icon="@android:drawable/ic_menu_view"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp"
                        app:iconTint="@color/fitzone_on_primary"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/summaryDivider" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>